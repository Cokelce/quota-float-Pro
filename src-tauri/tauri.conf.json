{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quota Float Pro",
  "version": "0.1.5",
  "identifier": "app.quotafloat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "widget",
        "title": "Quota Float Pro",
        "width": 80,
        "height": 80,
        "minWidth": 80,
        "minHeight": 80,
        "maxWidth": 520,
        "maxHeight": 568,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      },
      {
        "label": "settings",
        "title": "小组件设置",
        "url": "/?settings",
        "width": 460,
        "height": 560,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex quota and API balance at a glance",
    "longDescription": "A lightweight floating desktop card for Codex quota and API balance monitoring.",
    "copyright": "Copyright quota-float-Pro contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1QTdCQjM3ODU3ODU1NkQKUldSdFZYaUZON3VuRmFqL0U1V1RQM3VuejIxbnhIb2lHOFNVQjF5aUZqbm9UcGo3RHNUdVk4WHoK",
      "endpoints": ["https://github.com/Cokelce/quota-float-Pro/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
